{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "@cloudflare/workers-types",
      "node",
      "vitest/globals"
    ],
    "lib": [
      "ES2022",
      "DOM"
    ],
    "baseUrl": ".",
    "paths": {
      "@server/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "vitest.config.ts"
  ]
}
