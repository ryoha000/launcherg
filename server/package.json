{
  "name": "launcherg-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ui": "vite build --config ui/vite.config.ts",
    "build:ui:watch": "vite build --watch --config ui/vite.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p ui/tsconfig.json",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test && npm run build:ui",
    "dev": "wrangler dev",
    "dev:ui": "vite --config ui/vite.config.ts",
    "deploy": "npm run build:ui && wrangler deploy"
  },
  "dependencies": {
    "@orpc/client": "^1.9.0",
    "@orpc/server": "^1.9.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250321.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^24.0.13",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.9.1"
  },
  "packageManager": "npm@11.12.0"
}
